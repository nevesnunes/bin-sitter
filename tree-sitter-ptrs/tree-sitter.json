{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "ptrs",
      "camelcase": "Ptrs",
      "title": "Ptrs",
      "scope": "source.ptrs",
      "file-types": [
        "bin"
      ],
      "injection-regex": "^ptrs$",
      "class-name": "TreeSitterPtrs"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Ptrs grammar for tree-sitter",
    "authors": [
      {
        "name": "flib",
        "url": ""
      }
    ],
    "links": {
      "repository": "https://github.com/tree-sitter/tree-sitter-ptrs",
      "funding": ""
    }
  },
  "bindings": {
    "c": false,
    "go": false,
    "java": false,
    "node": false,
    "python": true,
    "rust": true,
    "swift": false,
    "zig": false
  }
}
